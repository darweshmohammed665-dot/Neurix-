{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User preferences and system configuration",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "theme": { "type": "string", "enum": ["dark", "light", "system"] },
        "sensitivity": { "type": "number", "description": "Gesture detection sensitivity" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "CustomGesture": {
      "title": "Custom Gesture",
      "description": "User-defined custom interaction gesture",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "action": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "trigger", "action"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Core user profile data"
    },
    "/users/{userId}/gestures/{gestureId}": {
      "schema": "CustomGesture",
      "description": "User-specific custom gestures"
    }
  }
}
